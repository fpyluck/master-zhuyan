{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex.local/master-zhuyan/research_brief.schema.json",
  "title": "MasterZhuyan Research Brief",
  "description": "Planner contract for turning a learner request and source map into research questions, teaching spine, and revision reasons.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "default": "1.0"
    },
    "brief_id": {
      "type": "string"
    },
    "topic_title": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "user_goal": {
      "type": "string",
      "description": "Remember, understand, compare, apply, review, create durable notes, resolve confusion, or mixed."
    },
    "learner_bottleneck": {
      "type": "string"
    },
    "primary_confusion": {
      "type": "string",
      "description": "The learner's main block or question the final package must resolve."
    },
    "success_criteria": {
      "type": "array",
      "description": "Observable criteria the chapter plan and final asset must satisfy.",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "source_map_ref": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "include": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "audience_level": {
          "type": "string"
        },
        "risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high", "unknown"]
        }
      }
    },
    "research_questions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/research_question"
      },
      "default": []
    },
    "source_strategy": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source_strategy_item"
      },
      "default": []
    },
    "selected_spine": {
      "type": "string",
      "description": "The causal, structural, procedural, or contrastive backbone for synthesis."
    },
    "chapter_emphasis": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["memory", "understanding", "comparison", "easy_error", "source_uncertainty", "application", "review"]
      },
      "default": []
    },
    "must_preserve_details": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "precision_anchors": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "agent_fabric_plan": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/agent_plan_item"
      },
      "default": []
    },
    "initial_continuation_branches": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/continuation_branch"
      },
      "default": []
    },
    "revision_reasons": {
      "type": "array",
      "description": "Evidence, scope, contradiction, precision, or teaching-quality reasons to revise planning before promotion.",
      "items": {
        "type": "string",
        "enum": ["insufficient_sources", "contradiction_blocks_spine", "missing_precision_anchor", "scope_too_broad", "high_risk_claim_needs_verification", "chapter_plan_repeats_itself", "user_goal_unclear"]
      },
      "default": []
    },
    "notes": {
      "type": "string"
    }
  },
  "required": ["brief_id", "topic_title", "user_goal", "primary_confusion", "success_criteria"],
  "$defs": {
    "research_question": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "question_id": {
          "type": "string"
        },
        "question": {
          "type": "string"
        },
        "purpose": {
          "type": "string",
          "enum": ["definition", "mechanism", "classification", "procedure", "comparison", "evidence", "boundary", "easy_error", "memory", "application"]
        },
        "required_source_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "status": {
          "type": "string",
          "enum": ["open", "answered", "partial", "needs_acquisition", "recorded_for_continuation"]
        }
      },
      "required": ["question"]
    },
    "source_strategy_item": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_type": {
          "type": "string"
        },
        "use_for": {
          "type": "string"
        },
        "acquisition_agent": {
          "type": "string"
        }
      },
      "required": ["source_type", "use_for"]
    },
    "agent_plan_item": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agent_id": {
          "type": "string"
        },
        "agent_type": {
          "type": "string"
        },
        "mission": {
          "type": "string"
        },
        "output_artifact": {
          "type": "string"
        }
      },
      "required": ["agent_type", "mission", "output_artifact"]
    },
    "continuation_branch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "branch": {
          "type": "string"
        },
        "why_it_may_expand": {
          "type": "string"
        }
      },
      "required": ["branch", "why_it_may_expand"]
    }
  }
}
