{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex.local/master-zhuyan/quality_report.schema.json",
  "title": "MasterZhuyan Quality Trace Report",
  "x-canonical-name": "quality_trace_report",
  "description": "Legacy-named contract for quality tracing: source support, teaching value, artifact/container repair, integrator action, and continuation candidates.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "default": "2.0"
    },
    "report_id": {
      "type": "string"
    },
    "topic_title": {
      "type": "string"
    },
    "lesson_plan_ref": {
      "type": "string"
    },
    "final_output_ref": {
      "type": "string"
    },
    "overall_state": {
      "type": "string",
      "enum": ["strong", "partial", "needs_revision", "not_applicable"]
    },
    "trace_results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/trace_result"
      },
      "default": []
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      },
      "default": []
    },
    "integrator_actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/integrator_action"
      },
      "default": []
    },
    "continuation_candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/continuation_candidate"
      },
      "default": []
    },
    "known_limitations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "notes": {
      "type": "string"
    }
  },
  "required": ["report_id", "overall_state"],
  "$defs": {
    "trace_result": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dimension": {
          "type": "string",
          "enum": [
            "delivery",
            "chapter_value",
            "coverage",
            "source_uncertainty",
            "teaching_value",
            "multi_agent",
            "prep_template",
            "responsiveness",
            "final_enhancement"
          ]
        },
        "support_state": {
          "type": "string",
          "enum": ["strong", "partial", "inferred", "missing", "contradicted", "not_applicable"]
        },
        "summary": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "integrator_action": {
          "$ref": "#/$defs/action_enum"
        },
        "continuation_ref": {
          "type": "string"
        }
      },
      "required": ["dimension", "support_state"]
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "finding_id": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": ["info", "minor", "major", "high_risk"]
        },
        "artifact_ref": {
          "type": "string",
          "description": "File path, chapter id, source id, evidence card id, or section reference."
        },
        "issue": {
          "type": "string"
        },
        "support_state": {
          "type": "string",
          "enum": ["strong", "partial", "inferred", "missing", "contradicted", "not_applicable"]
        },
        "suggested_action": {
          "$ref": "#/$defs/action_enum"
        },
        "source_needed": {
          "type": "string",
          "enum": ["yes", "no", "unknown"]
        },
        "continuation_ref": {
          "type": "string"
        }
      },
      "required": ["severity", "issue", "support_state"]
    },
    "integrator_action": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "action_id": {
          "type": "string"
        },
        "action": {
          "$ref": "#/$defs/action_enum"
        },
        "artifact_ref": {
          "type": "string"
        },
        "result": {
          "type": "string"
        }
      },
      "required": ["action"]
    },
    "continuation_candidate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "candidate_id": {
          "type": "string"
        },
        "topic": {
          "type": "string"
        },
        "current_state": {
          "type": "string"
        },
        "next_agent": {
          "type": "string"
        },
        "input_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "expected_output": {
          "type": "string"
        },
        "core_relevance": {
          "type": "string",
          "enum": ["core", "non_core_extension"]
        }
      },
      "required": ["topic", "current_state", "core_relevance"]
    },
    "action_enum": {
      "type": "string",
      "enum": [
        "accept",
        "revise",
        "create_missing_artifact",
        "dispatch_agent",
        "soften_claim",
        "omit_claim",
        "mark_unavailable",
        "record_continuation"
      ]
    }
  }
}
